@page "/"
@implements IAsyncDisposable
@inject WebGameService GameSvc
@inject LanguageService LangSvc
@inject IJSRuntime JS

<PageTitle>Pontinho</PageTitle>

<div class="game-container players-@(IsSimulationLayout ? GameSvc.RoundCpus.Count : GameSvc.ActiveLayoutCount) @(GameSvc.Cpus.Count == 1 ? "layout-2p" : "") @(GameSvc.IsSimulationMode ? "sim-mode" : "") @(SimSeatCount != 1 && SimSeatCount != 3 && SimSeatCount != 6 && SimSeatCount != 7 ? "expand-table" : "") @(_tableExpanded ? "table-expanded" : "") @(_combosShrunk ? "combos-shrunk" : "") @(_dealRevealCounts.Count > 0 ? "dealing" : "") @(GameSvc.ActiveLayoutCount > 4 ? "side-compact" : "") @(_showGhostSlots ? "show-ghost-slots" : "")">

    @if (GameSvc.Phase == GamePhase.Welcome)
    {
        <div class="welcome-screen">
            <div class="welcome-table">
            <!-- Large atmospheric suit symbols in corners -->
            <div class="wc-bg" aria-hidden="true">
                <span class="wc-bg-s wc-bg-tl">♠</span>
                <span class="wc-bg-s wc-bg-tr red">♥</span>
                <span class="wc-bg-s wc-bg-bl red">♦</span>
                <span class="wc-bg-s wc-bg-br">♣</span>
            </div>

            <div class="welcome-inner">
                <!-- Title -->
                <div class="welcome-hero">
                    <h1 class="welcome-title">PONTINHO</h1>
                    <div class="welcome-divider" aria-hidden="true">
                        <span class="wd-line"></span>
                        <span class="wd-suit">♠</span>
                        <span class="wd-suit red">♥</span>
                        <span class="wd-suit red">♦</span>
                        <span class="wd-suit">♣</span>
                        <span class="wd-line"></span>
                    </div>
                    <p class="welcome-subtitle">@LangSvc.Subtitle</p>
                </div>

                <!-- Settings panel -->
                <div class="welcome-panel">
                    <div class="lang-picker">
                        <button class="btn-lang @(LangSvc.Language == AppLanguage.English ? "active" : "")"
                                @onclick="() => SetLanguage(AppLanguage.English)">English</button>
                        <button class="btn-lang @(LangSvc.Language == AppLanguage.Portuguese ? "active" : "")"
                                @onclick="() => SetLanguage(AppLanguage.Portuguese)">Português</button>
                    </div>
                    <div class="welcome-settings">
                        <div class="ws-field ws-field-full">
                            <label class="ws-label" for="name-input">@LangSvc.YourNameLabel</label>
                            <input id="name-input" class="diff-select" type="text" maxlength="8"
                                   placeholder="@LangSvc.YourNamePlaceholder"
                                   @bind="GameSvc.PlayerName" @bind:event="oninput" />
                        </div>
                        <div class="ws-field">
                            <label class="ws-label" for="cpu-count-select">@LangSvc.CpuCountLabel</label>
                            <select id="cpu-count-select" class="diff-select"
                                    @bind="GameSvc.CpuCount">
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                                <option value="7">7</option>
                            </select>
                        </div>
                    </div>
                    <div class="welcome-actions">
                        <button class="btn-start" @onclick="DoStartGame">@LangSvc.StartGame</button>
                        <button class="btn-rules" @onclick="() => _showRules = true">@LangSvc.RulesBtn</button>
                    </div>
                </div>

                <!-- Decorative card fan -->
                <div class="welcome-fan" aria-hidden="true">
                    <div class="wf-card"></div>
                    <div class="wf-card"></div>
                    <div class="wf-card"></div>
                    <div class="wf-card"></div>
                    <div class="wf-card"></div>
                    <div class="wf-card"></div>
                    <div class="wf-card"></div>
                </div>
            </div>
            </div> <!-- /welcome-table -->
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="header">
            <span class="game-title">PONTINHO</span>
            <div class="header-btns">
                <button class="btn-rules-header" @onclick="() => _showRules = true">@LangSvc.RulesBtn</button>
                <button class="btn-rules-header" @onclick="() => _showAbout = true">@LangSvc.AboutBtn</button>
                <button class="btn-sound-header" title="@(_soundEnabled ? "Mute sounds" : "Unmute sounds")" @onclick="ToggleSound">@(_soundEnabled ? "🔊" : "🔇")</button>
                <button class="btn-quit-header" @onclick="OnQuitClick">@LangSvc.QuitBtn</button>
            </div>
        </div>

        <!-- Game layout: [table] [results panel] — header-btns and results panel share the same grid column -->
        <div class="game-layout">
        <div class="game-table-wrap">
        <div class="game-table">

        <!-- CPU seats. Anti-clockwise: right side first, then top, then left.
             count==6 (7-player): right stack=CPUs 0,1; top pair=CPUs 2(right),3(left); left stack=CPUs 4,5.
             count==7 (8-player): bottom-right=CPU0; right stack=CPUs 1,2; top pair=CPUs 3(right),4(left); left stack=CPUs 5,6.
             For other counts, uses GetSeat. For 5-CPU count, index 2 goes inside seat-center. -->
        @if (UpperCpus.Count == 6)
        {
            var _c0 = UpperCpus[0]; var _c0a = IsCpuActive(_c0);
            var _c1 = UpperCpus[1]; var _c1a = IsCpuActive(_c1);
            var _c2 = UpperCpus[2]; var _c2a = IsCpuActive(_c2);
            var _c3 = UpperCpus[3]; var _c3a = IsCpuActive(_c3);
            var _c4 = UpperCpus[4]; var _c4a = IsCpuActive(_c4);
            var _c5 = UpperCpus[5]; var _c5a = IsCpuActive(_c5);
            <div class="seat-left-stack">
                <div class="player-section seat-left @(_c4a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c4.Name) { <span class="sh-first-badge">1°</span> }@_c4.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c4.Id)) { @foreach (var c in CpuHandForDisplay(_c4)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c4.Id, _c4.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
                <div class="player-section seat-left @(_c5a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c5.Name) { <span class="sh-first-badge">1°</span> }@_c5.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c5.Id)) { @foreach (var c in CpuHandForDisplay(_c5)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c5.Id, _c5.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
            <div class="seat-top-pair">
                <div class="player-section @(_c3a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c3.Name) { <span class="sh-first-badge">1°</span> }@_c3.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-horiz">
                        @if (ShowCpuHandFaceUp(_c3.Id)) { @foreach (var c in CpuHandForDisplay(_c3)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c3.Id, _c3.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
                <div class="player-section @(_c2a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c2.Name) { <span class="sh-first-badge">1°</span> }@_c2.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-horiz">
                        @if (ShowCpuHandFaceUp(_c2.Id)) { @foreach (var c in CpuHandForDisplay(_c2)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c2.Id, _c2.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
            <div class="seat-right-stack">
                <div class="player-section seat-right @(_c1a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c1.Name) { <span class="sh-first-badge">1°</span> }@_c1.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c1.Id)) { @foreach (var c in CpuHandForDisplay(_c1)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c1.Id, _c1.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
                <div class="player-section seat-right @(_c0a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c0.Name) { <span class="sh-first-badge">1°</span> }@_c0.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c0.Id)) { @foreach (var c in CpuHandForDisplay(_c0)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c0.Id, _c0.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
        }
        else if (UpperCpus.Count == 7)
        {
            var _c1 = UpperCpus[1]; var _c1a = IsCpuActive(_c1);
            var _c2 = UpperCpus[2]; var _c2a = IsCpuActive(_c2);
            var _c3 = UpperCpus[3]; var _c3a = IsCpuActive(_c3);
            var _c4 = UpperCpus[4]; var _c4a = IsCpuActive(_c4);
            var _c5 = UpperCpus[5]; var _c5a = IsCpuActive(_c5);
            var _c6 = UpperCpus[6]; var _c6a = IsCpuActive(_c6);
            <div class="seat-left-stack">
                <div class="player-section seat-left @(_c5a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c5.Name) { <span class="sh-first-badge">1°</span> }@_c5.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c5.Id)) { @foreach (var c in CpuHandForDisplay(_c5)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c5.Id, _c5.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
                <div class="player-section seat-left @(_c6a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c6.Name) { <span class="sh-first-badge">1°</span> }@_c6.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c6.Id)) { @foreach (var c in CpuHandForDisplay(_c6)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c6.Id, _c6.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
            <div class="seat-top-pair">
                <div class="player-section @(_c4a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c4.Name) { <span class="sh-first-badge">1°</span> }@_c4.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-horiz">
                        @if (ShowCpuHandFaceUp(_c4.Id)) { @foreach (var c in CpuHandForDisplay(_c4)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c4.Id, _c4.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
                <div class="player-section @(_c3a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c3.Name) { <span class="sh-first-badge">1°</span> }@_c3.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-horiz">
                        @if (ShowCpuHandFaceUp(_c3.Id)) { @foreach (var c in CpuHandForDisplay(_c3)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c3.Id, _c3.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
            <div class="seat-right-stack">
                <div class="player-section seat-right @(_c2a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c2.Name) { <span class="sh-first-badge">1°</span> }@_c2.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c2.Id)) { @foreach (var c in CpuHandForDisplay(_c2)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c2.Id, _c2.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
                <div class="player-section seat-right @(_c1a ? "active-player" : "")">
                    <div class="section-title">@if (GameSvc.FirstPlayerName == _c1.Name) { <span class="sh-first-badge">1°</span> }@_c1.Name <span class="cpu-label">(@LangSvc.AiLabel)</span></div>
                    <div class="hand hand-side">
                        @if (ShowCpuHandFaceUp(_c1.Id)) { @foreach (var c in CpuHandForDisplay(_c1)) { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> } }
                        else { @for (int i = 0; i < DealCardCount(_c1.Id, _c1.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
        }
        else
        {
            @for (int ci = 0; ci < UpperCpus.Count; ci++)
            {
                if (UpperCpus.Count >= 5 && ci == 2) continue; // top CPU rendered inside seat-center
                var cpu = UpperCpus[ci];
                string seat = GetSeat(ci, SimSeatCount);
                bool isCpuActive = IsCpuActive(cpu);
                bool isSide = seat is "left" or "right" or "top-left" or "top-right";
                <div class="player-section seat-@seat @(isCpuActive ? "active-player" : "")">
                    <div class="section-title">
                        @if (GameSvc.FirstPlayerName == cpu.Name) { <span class="sh-first-badge">1°</span> }@cpu.Name <span class="cpu-label">(@LangSvc.AiLabel)</span>
                    </div>
                    <div class="hand @(isSide ? "hand-side" : "hand-horiz")">
                        @if (ShowCpuHandFaceUp(cpu.Id))
                        {
                            @foreach (var c in CpuHandForDisplay(cpu))
                            {
                                <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div>
                            }
                        }
                        else
                        {
                            @for (int i = 0; i < DealCardCount(cpu.Id, cpu.Hand.Count); i++)
                            {
                                <div class="card face-down"></div>
                            }
                        }
                    </div>
                </div>
            }
        }

        <!-- Center column: table area + player hand.
             In 6-player the top-center CPU is also rendered here at the top. -->
        <div class="seat-center">

        @if (UpperCpus.Count >= 5 && UpperCpus.Count != 6 && UpperCpus.Count != 7)
        {
            var topCpu = UpperCpus[2];
            bool isCpuActive = IsCpuActive(topCpu);
            <div class="seat-top-inner">
                <div class="player-section seat-top @(isCpuActive ? "active-player" : "")">
                    <div class="section-title">
                        @if (GameSvc.FirstPlayerName == topCpu.Name) { <span class="sh-first-badge">1°</span> }@topCpu.Name <span class="cpu-label">(@LangSvc.AiLabel)</span>
                    </div>
                    <div class="hand">
                        @if (ShowCpuHandFaceUp(topCpu.Id))
                        {
                            @foreach (var c in CpuHandForDisplay(topCpu))
                            {
                                <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div>
                            }
                        }
                        else
                        {
                            @for (int i = 0; i < DealCardCount(topCpu.Id, topCpu.Hand.Count); i++)
                            {
                                <div class="card face-down"></div>
                            }
                        }
                    </div>
                </div>
            </div>
        }

<!-- Table -->
        <div class="table-area @(IsTableDropTarget ? "drop-target-table" : "")"
             @ondrop="OnDropToTable">

            <div class="combos-scroll">
            @if (GameSvc.State!.Table.Combinations.Count == 0)
            {
                <div class="empty-table">@LangSvc.EmptyTable</div>
            }
            else
            {
                var combos = GameSvc.State.Table.Combinations;
                var draggedCard = _dragFrom >= 0 && _dragFrom < GameSvc.MainPlayer.Hand.Cards.Count
                    ? GameSvc.MainPlayer.Hand.Cards[_dragFrom] : null;

                int selCount = GameSvc.SelectedCards.Count;
                // Single-card highlight (also gates swap detection)
                bool showAddHighlight = !AnyDragging
                    && GameSvc.Phase == GamePhase.AwaitingAction
                    && selCount == 1;
                // Multi-card highlight for 2+ selected cards
                bool showMultiHighlight = !AnyDragging
                    && GameSvc.Phase == GamePhase.AwaitingAction
                    && selCount > 1;

                <div class="combos-grid">
                @foreach (var ci in Enumerable.Range(0, combos.Count)
                    .Where(i => _cpuRevealComboCount < 0 || i < _cpuRevealComboCount || _cpuHiddenCards.ContainsKey(i)))
                {
                    var combo = combos[ci];
                    var comboIdx = ci;
                    var hiddenForCombo = _cpuHiddenCards.GetValueOrDefault(comboIdx);
                    int cardLimit = hiddenForCombo != null ? combo.Cards.Count - hiddenForCombo.Count : combo.Cards.Count;
                    bool isWinning = GameSvc.IsWinningMove(1);
                    bool isWinningMulti = GameSvc.IsWinningMove(selCount);

                    bool canAddSingle = showAddHighlight
                        && combo.CanAccept(GameSvc.SelectedCards.First(), isWinning);
                    bool canAddMulti = showMultiHighlight
                        && combo.CanAcceptAll(GameSvc.SelectedCards.ToList(), isWinningMulti);

                    bool canAddSelected = canAddSingle || canAddMulti;
                    bool cannotAddSelected = (showAddHighlight && !canAddSingle) || (showMultiHighlight && !canAddMulti);

                    bool isMultiDrag = draggedCard != null && selCount > 1
                        && GameSvc.SelectedCards.Contains(draggedCard);
                    bool isDragTarget = GameSvc.Phase == GamePhase.AwaitingAction && draggedCard != null
                        && (GameSvc.SelectedCards.Count == 0
                            || (GameSvc.SelectedCards.Count == 1 && GameSvc.SelectedCards.Contains(draggedCard))
                            || isMultiDrag);
                    bool isDropTarget = isDragTarget && (isMultiDrag
                        ? combo.CanAcceptAll(GameSvc.SelectedCards.ToList(), isWinningMulti)
                        : combo.CanAccept(draggedCard!, isWinning) || combo.CanReplaceJoker(draggedCard!));

                    bool canSwap = showAddHighlight && combo.CanReplaceJoker(GameSvc.SelectedCards.First());
                    bool canReturnJoker = showAddHighlight
                        && GameSvc.SwappedJokerComboIndex == comboIdx
                        && combo.CanReturnJoker(GameSvc.SelectedCards.First());

                    bool actionable = GameSvc.Phase == GamePhase.AwaitingAction;
                    bool isTriple = combo.Type == CombinationType.Triple;
                    string rowClass = isDropTarget                             ? "combo-row drop-target clickable"
                                    : canReturnJoker                           ? "combo-row combo-can-accept clickable"
                                    : actionable                               ? "combo-row clickable"
                                    :                                            "combo-row";

                    int maxCapacity = isTriple ? Combination.MaxTripleSize : Combination.MaxSequenceSize;
                    // Triples: each added card fills the leftmost ghost slot (count down from MaxTripleSize).
                    // Sequences batch-cycle 3→2→1→3…
                    // No ghost slots on the winning lay-down combo.
                    // On a winning add-to-combo: suppress creating a new batch when the last ghost slot was
                    // just filled (Count % 3 == 0 → would jump 1→3). Mid-batch adds (2→1 or 3→2) need no
                    // special handling. Triples don't batch-cycle so no suppression needed there.
                    bool suppressNewBatch = combo.IsWinningAddition && !isTriple && combo.Cards.Count % 3 == 0;
                    // For NEW combos being revealed card-by-card: suppress ghost slots until all cards land.
                    // For EXISTING combos being extended: base ghosts on cardLimit (visible count) so the
                    // layout stays stable while the incoming card is in flight.
                    bool revealInProgress = hiddenForCombo != null && hiddenForCombo.Count > 0;
                    bool isNewCombo = _newComboIndices.Contains(comboIdx);
                    int ghostBase = (revealInProgress && !isNewCombo) ? cardLimit : combo.Cards.Count;
                    int batchGhostCount = combo.IsWinningLaydown || suppressNewBatch
                        || ghostBase >= maxCapacity || (isNewCombo && revealInProgress)
                        ? 0
                        : isTriple ? maxCapacity - ghostBase
                                   : Math.Min((ghostBase / 3 + 1) * 3 - ghostBase,
                                              maxCapacity - ghostBase);
                    double seqStep = _combosShrunk ? 0.33 : 0.5;
                    double ghostStep = isTriple ? 0.33 : seqStep;
                    double ghostStart = isTriple
                        ? 2.0 + Math.Max(0, ghostBase - 3) * 0.33
                        : 1.0 + (ghostBase - 1) * seqStep;
                    double ghostPad = batchGhostCount > 0 && !isTriple
                        ? (batchGhostCount - 1) * seqStep + seqStep
                        : 0.0;
                    var inv = System.Globalization.CultureInfo.InvariantCulture;
                    string comboRowStyle = $"--ghost-start:{ghostStart.ToString("F2", inv)};--ghost-step:{ghostStep.ToString("F2", inv)};--combo-ghost-pad:{ghostPad.ToString("F2", inv)}";

                    <div class="@rowClass"
                         style="@comboRowStyle"
                         data-combo-idx="@comboIdx"
                         @ondrop:stopPropagation="isDropTarget"
                         @ondrop="() => OnDropToCombo(comboIdx, isDropTarget)"
                         @onclick="() => OnComboRowClick(comboIdx)">
                        @foreach (var tableCard in combo.Cards.Where(c => hiddenForCombo == null || !hiddenForCombo.Contains(c)))
                        {
                            bool swappable = canSwap && tableCard.IsJoker;
                            bool isBurnCard = GameSvc.TripleDiscardsPending.Any(t => t.ComboIndex == comboIdx && ReferenceEquals(t.Card, tableCard))
                                           || GameSvc.CpuTripleDiscardsPending.Any(t => t.ComboIndex == comboIdx && ReferenceEquals(t.Card, tableCard));
                            <div @key="tableCard"
                                 class="card @CardClass(tableCard) @(swappable ? "joker-swappable" : "") @(isBurnCard ? "card-triple-burn" : "")"
                                 @onclick:stopPropagation="swappable"
                                 @onclick="() => OnTableCardClick(comboIdx, swappable)">
                                <CardDisplay Card="tableCard" />
                            </div>
                        }
                        @for (int g = 0; g < batchGhostCount; g++)
                        {
                            if (isTriple)
                            {
                                // Flex item — no absolute positioning, always visible
                                <div class="card-ghost-triple"></div>
                            }
                            else
                            {
                                <div class="card card-ghost" style="--ghost-i:@g"></div>
                            }
                        }
                        <span class="combo-label">@(GameSvc.AllPlayers.FirstOrDefault(p => p.Id == combo.OwnerId)?.Name ?? LangSvc.AiLabel)</span>
                        @if (canReturnJoker)
                        {
                            <span class="combo-add-badge swap-badge">@LangSvc.ReturnJokerBadge</span>
                        }
                    </div>
                }
                </div>
            }
            </div><!-- /combos-scroll -->

            <!-- Deck and discard piles -->
            <div class="piles-row">
                <div class="pile">
                    @{
                        bool deckDraggable = GameSvc.Phase == GamePhase.AwaitingDraw && _dealRevealCounts.Count == 0;
                        bool deckReturnTarget = GameSvc.Phase == GamePhase.AwaitingAction && GameSvc.HasUnusedDiscardCard && _dragFrom >= 0;
                    }
                    <div class="deck-drop-zone @(deckReturnTarget ? "drop-target" : "")"
                         @ondrop="OnDropToDeck">
                        <div class="card face-down @(deckDraggable ? "clickable" : "")"
                             draggable="@(deckDraggable ? "true" : "false")"
                             @onclick="DoDraw"
                             @ondragstart="OnDragStartDeck"
                             @ondragend="OnDragEnd">
                        </div>
                    </div>
                </div>
                <div class="pile @(GameSvc.HasSecondDrawPrivilege ? "second-draw-active" : "") @(GameSvc.HasUnusedDiscardCard ? "return-card-active" : "")">
                    @if (GameSvc.HasSecondDrawPrivilege)
                    {
                        <div class="second-draw-badge">@LangSvc.SecondDrawHint</div>
                    }
                    @if (GameSvc.HasUnusedDiscardCard)
                    {
                        <button class="return-card-btn" @onclick="() => GameSvc.ReturnDiscardCard()">@LangSvc.ReturnCardBadge</button>
                    }
                    <div class="discard-drop-zone @(IsDiscardDropTarget ? "drop-target" : "")"
                         @ondrop="OnDropToDiscard">
                        <div class="pile-stack">
                            @if (GameSvc.State.Deck.DiscardTop != null)
                            {
                                var top = GameSvc.State.Deck.DiscardTop;
                                bool discardClickable = GameSvc.Phase == GamePhase.AwaitingDraw && !GameSvc.MustDrawFromDeck && _dealRevealCounts.Count == 0;
                                var allDiscard = GameSvc.State.Deck.DiscardPeek(GameSvc.State.Deck.DiscardPileCount);
                                @for (int gi = 0; gi < allDiscard.Count - 1; gi++)
                                {
                                    var g = allDiscard[gi];
                                    <div class="card @CardClass(g) pile-ghost" style="--pile-rot:@(DiscardAngle(g))deg"><CardDisplay Card="g" /></div>
                                }
                                <div @key="top" class="card @CardClass(top) discard-top @(discardClickable ? "clickable" : "")"
                                     style="--pile-rot:@(DiscardAngle(top))deg"
                                     draggable="@(discardClickable ? "true" : "false")"
                                     @onclick="DoDrawDiscard"
                                     @ondragstart="OnDragStartDiscard"
                                     @ondragend="OnDragEnd"><CardDisplay Card="top" /></div>
                            }
                            else
                            {
                                <div class="card empty-pile">@LangSvc.Empty</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom row: [bottom-left CPU (7+ players)] + player hand + [bottom-right CPU (8 players)] -->
        <div class="seat-bottom-row">

        <div class="seat-bottom">

        @if (IsSimulationLayout && ActiveCpus.Count > 0)
        {
            var simBottomCpu = ActiveCpus[0];
            bool simBottomActive = IsCpuActive(simBottomCpu);
            <div class="player-section @(simBottomActive ? "active-player" : "")">
                <div class="section-title">
                    @if (GameSvc.FirstPlayerName == simBottomCpu.Name) { <span class="sh-first-badge">1°</span> }@simBottomCpu.Name <span class="cpu-label">(@LangSvc.AiLabel)</span>
                </div>
                <div class="hand hand-horiz">
                    @if (ShowCpuHandFaceUp(simBottomCpu.Id))
                    {
                        @foreach (var c in CpuHandForDisplay(simBottomCpu))
                        {
                            <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div>
                        }
                    }
                    else
                    {
                        @for (int i = 0; i < DealCardCount(simBottomCpu.Id, simBottomCpu.Hand.Count); i++) { <div class="card face-down"></div> }
                    }
                </div>
            </div>
        }
        else if (IsSimulationLayout)
        {
            <!-- Player eliminated — show name only, no cards -->
            <div class="player-section sim-eliminated">
                <div class="section-title">@GameSvc.MainPlayer.Name</div>
                <div class="hand hand-horiz"></div>
            </div>
        }
        else
        {
            <!-- Player hand -->
            bool isMainPlayerActive = GameSvc.Phase is GamePhase.AwaitingDraw or GamePhase.AwaitingAction;
            <div class="player-section @(IsHandDropTarget ? "drop-target-hand" : "") @(isMainPlayerActive ? "active-player" : "")"
                 @ondrop="OnDropToHandSection">
                <div class="section-title">
                    @if (GameSvc.IsMainPlayerFirst) { <span class="sh-first-badge">1°</span> }@GameSvc.MainPlayer.Name
                </div>
                <div class="hand">
                    <div class="hand-endzone @(AnyDragging ? "visible" : "")"
                         @ondrop:stopPropagation="true"
                         @ondrop="OnDropToStart"></div>
                    <div class="hand-fan">
                    @for (int hi = 0; hi < DealCardCount(GameSvc.MainPlayer.Id, GameSvc.MainPlayer.Hand.Cards.Count); hi++)
                    {
                        var card = GameSvc.MainPlayer.Hand.Cards[hi];
                        var idx = hi;
                        bool sel = GameSvc.SelectedCards.Contains(card);
                        bool dragging = _dragFrom >= 0 && (_dragFrom == idx || GameSvc.SelectedCards.Contains(card));
                        bool justDrawn = ReferenceEquals(card, _justDrawnCard);
                        <div class="card @CardClass(card) @(sel ? "selected" : "") @(dragging ? "dragging" : "") @(justDrawn ? "card-drawn-in" : "")"
                             draggable="true"
                             data-rank="@((int)card.Rank)"
                             @onclick="() => DoToggleCard(card)"
                             @ondragstart="() => OnDragStart(idx)"
                             @ondrop:stopPropagation="true"
                             @ondrop="() => OnDropOnHandCard(idx)"
                             @ondragend="OnDragEnd"><CardDisplay Card="card" /></div>
                    }
                    </div>
                    <div class="hand-endzone @(AnyDragging ? "visible" : "")"
                         @ondrop:stopPropagation="true"
                         @ondrop="OnDropToEnd"></div>
                </div>
            </div>
        }

        </div> <!-- /seat-bottom -->

        @if (UpperCpus.Count >= 7)
        {
            var brCpu = UpperCpus[0]; // anti-clockwise: CPU 0 is immediately to the right of the player
            bool brActive = IsCpuActive(brCpu);
            <div class="seat-bottom-side side-right">
                <div class="player-section @(brActive ? "active-player" : "")">
                    <div class="section-title">
                        @if (GameSvc.FirstPlayerName == brCpu.Name) { <span class="sh-first-badge">1°</span> }@brCpu.Name <span class="cpu-label">(@LangSvc.AiLabel)</span>
                    </div>
                    <div class="hand hand-horiz">
                        @if (ShowCpuHandFaceUp(brCpu.Id))
                        {
                            @foreach (var c in CpuHandForDisplay(brCpu))
                            { <div @key="c" class="card @HandCardClass(c)"><CardDisplay Card="c" /></div> }
                        }
                        else
                        { @for (int i = 0; i < DealCardCount(brCpu.Id, brCpu.Hand.Count); i++) { <div class="card face-down"></div> } }
                    </div>
                </div>
            </div>
        }

        </div> <!-- /seat-bottom-row -->

        </div> <!-- /seat-center -->
        </div> <!-- /game-table -->

        </div> <!-- /game-table-wrap -->

        <!-- Results panel slot — table visible whenever there is history; buttons only at round/game end -->
        @{
            bool isGameOver = GameSvc.GameWinner != null || GameSvc.PendingGameWinner != null;
            var gameOverWinner = GameSvc.GameWinner ?? GameSvc.PendingGameWinner;
            var histPlayers = GameSvc.AllPlayers;
            var history = GameSvc.RoundHistory;
            bool isRoundEnd = !_cpuRunning && GameSvc.Phase is GamePhase.RoundOver or GamePhase.GameOver;
        }
        <div class="game-results-slot">
            <div class="round-over-panel">
                <div class="score-history-wrap">
                    <table class="score-history">
                        <thead>
                            <tr>
                                <th class="sh-round">#</th>
                                @foreach (var p in histPlayers)
                                {
                                    <th title="@p.Name">@p.Name</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rec in history)
                            {
                                <tr>
                                    <td class="sh-round">@rec.Round</td>
                                    @foreach (var p in histPlayers)
                                    {
                                        bool played = rec.Penalties.TryGetValue(p.Id, out var pv);
                                        int pen = played ? pv : 0;
                                        bool isWinner = played && pen == 0;
                                        bool isFirst = rec.FirstPlayerId == p.Id;
                                        <td class="@(!played ? "sh-absent" : isWinner ? "sh-win" : "sh-lose")">
                                            <span class="sh-penalty">@(!played ? "—" : isWinner ? "–" : $"{pen}")</span>
                                        </td>
                                    }
                                </tr>
                            }
                            @if (!isRoundEnd)
                            {
                                <tr class="sh-current">
                                    <td class="sh-round">@GameSvc.RoundNumber</td>
                                    @foreach (var p in histPlayers)
                                    {
                                        <td>—</td>
                                    }
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="sh-footer">
                                <td class="sh-round"></td>
                                @foreach (var p in histPlayers)
                                {
                                    int total = p.Score;
                                    bool isGameWinner = GameSvc.GameWinner?.Id == p.Id;
                                    <td class="@(isGameWinner ? "sh-win" : total >= 100 ? "sh-elim" : "")">@(total >= 100 && !isGameWinner ? "❌" : total)</td>
                                }
                            </tr>
                        </tfoot>
                    </table>
                </div>
                @if (GameSvc.IsSimulationMode && !isGameOver)
                {
                    <button class="btn-skip-sim" @onclick="SkipSimulation">@LangSvc.SkipSimBtn</button>
                }
                <div class="panel-messages-area">
                    @if (GameSvc.Message != null)
                    {
                        <span class="panel-message">@GameSvc.Message</span>
                    }
                    @if (GameSvc.ErrorMessage != null)
                    {
                        <span class="panel-message error">@GameSvc.ErrorMessage</span>
                    }
                </div>
                @if (isRoundEnd)
                {
                    @if (isGameOver)
                    {
                        <button class="btn-primary" @onclick="DoStartGame">@LangSvc.NewGame</button>
                    }
                    else
                    {
                        <button class="btn-primary" @onclick="OnNextRoundClick">@LangSvc.NextRound (@_countdown)</button>
                    }
                }
            </div>
        </div> <!-- /game-results-slot -->

        </div> <!-- /game-layout -->
    }

</div>

